@model List<VirtualClassroom.Core.TblMaterials>

@{
    Layout = "~/Views/Faculty/_FacultyLayout.cshtml";
    ViewData["Title"] = "Materials";
}

<link rel="stylesheet" href="~/css/material-list.css" asp-append-version="true" />

<div class="material-table-container">

    <!-- HEADER -->
    <div class="header-row">
        <h2>📂 Materials</h2>

        <a class="btn-add"
           href="/Material/Add?classroomId=@ViewBag.ClassroomId">
            + Add Material
        </a>
    </div>

    <!-- TABLE -->
    <table class="material-table">

        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>File</th>
                <th style="width:150px;">Action</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Description</td>

                        <td>
                            <a href="@item.FilePath" target="_blank" class="download-link">
                                ⬇ Download
                            </a>
                        </td>

                        <td>
                            <div class="action-group">

                                <a href="/Material/Edit/@item.MaterialId"
                                   class="btn-edit">
                                    Edit
                                </a>

                                <a href="/Material/Delete/@item.MaterialId"
                                   onclick="return confirm('Are you sure?')"
                                   class="btn-delete">
                                    Delete
                                </a>

                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="no-data">
                        No materials available
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>