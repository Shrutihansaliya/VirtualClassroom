@{
}
@model List<VirtualClassroom.Core.TblMaterials>

@{
    Layout = "~/Views/Student/_StudentLayout.cshtml";
}

<style>
    .page-title {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 20px;
        color: #333;
    }

    .material-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-top: 10px;
    }

    .material-card {
        background: #fff;
        border-radius: 14px;
        padding: 16px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        transition: 0.25s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 180px;
    }

        .material-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

    .material-header {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 10px;
        color: #222;
    }

    .material-body {
        flex: 1;
    }

        .material-body p {
            font-size: 14px;
            color: #555;
            margin-bottom: 10px;
        }

    .material-date {
        font-size: 12px;
        color: #888;
    }

    .material-footer {
        margin-top: 15px;
        display: flex;
        justify-content: space-between;
        gap: 10px;
    }

    .btn {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 13px;
        text-decoration: none;
        font-weight: 500;
        transition: 0.2s;
        text-align: center;
    }

    .btn-view {
        border: 1px solid #2d5bff;
        color: #2d5bff;
        background: #f0f4ff;
    }

        .btn-view:hover {
            background: #2d5bff;
            color: #fff;
        }

    .btn-download {
        background: #2d5bff;
        color: #fff;
        border: none;
    }

        .btn-download:hover {
            background: #1f45d8;
        }

    .empty-text {
        color: #777;
        font-size: 14px;
        margin-top: 10px;
    }
</style>

<h2 class="page-title">Class Materials</h2>

@if (Model == null || !Model.Any())
{
    <p class="empty-text">No materials uploaded yet.</p>
}
else
{
    <div class="material-grid">

        @foreach (var item in Model)
        {
            <div class="material-card">

                <div class="material-header">
                    📘 @item.Title
                </div>

                <div class="material-body">
                    <p>@item.Description</p>

                    <div class="material-date">
                        Uploaded: @item.UploadedAt.ToString("dd-MM-yyyy")
                    </div>
                </div>

                <div class="material-footer">

                    @* <a href="@item.FilePath" *@
                    @*    target="_blank" *@
                    @*    class="btn btn-view"> *@
                    @*     View *@
                    @* </a> *@

                    <a href="@item.FilePath"
                       download
                       class="btn btn-download">
                        Download
                    </a>

                </div>

            </div>
        }

    </div>
}