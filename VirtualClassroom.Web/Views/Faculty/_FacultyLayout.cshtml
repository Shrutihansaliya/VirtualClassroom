<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/faculty.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <ul>
            <li><a asp-controller="Faculty" asp-action="Dashboard"><i class="bi bi-house"></i><span>Dashboard</span></a></li>
            <li><i class="bi bi-plus-circle"></i><span>Create Class</span></li>
            <li><i class="bi bi-journal"></i><span>My Classes</span></li>
            <li><i class="bi bi-person-plus"></i><span>Invite Students</span></li>
            <li><i class="bi bi-file-text"></i><span>Assignments</span></li>
            <li><i class="bi bi-camera-video"></i><span>Sessions</span></li>
        </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">

        <!-- NAVBAR -->
        <div class="navbar">
            <h4>Faculty Classroom</h4>
        </div>

        <!-- PAGE CONTENT -->
        <div class="content">
            @RenderBody()
        </div>

    </div>

</body>
</html>