



<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

   
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/faculty.css" />
    <link rel="stylesheet" href="~/css/faculty-dashboard.css" asp-append-version="true" />
    <link href="~/css/profile-dropdown.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="menu-icon">
            <i class="bi bi-list"></i>
        </div>
       
        <ul>
            <li><a asp-controller="Faculty" asp-action="Dashboard"><i class="bi bi-house"></i><span>Dashboard</span></a></li>
            @* <li><i class="bi bi-plus-circle"></i><span>Create Class</span></li> *@
            <li>
                <a asp-controller="Classroom"
                   asp-action="Create">
                    <i class="bi bi-plus-circle"></i>
                    <span>Create Class</span>
                </a>
            </li>
           
            <li>
                <a asp-controller="AssignmentFaculty" asp-action="Classrooms">
                    <i class="bi bi-file-text"></i>
                    <span>Assignments</span>
                </a>
            </li>
         
            <li>
                <a asp-controller="Material" asp-action="Classrooms">
                    <i class="bi bi-upload"></i>
                    <span>Materials</span>
                </a>
            </li>
            
        </ul>
    </div>

    <!-- MAIN -->
    <div class="main">

        <!-- NAVBAR -->
        <div class="navbar">

            <!-- LEFT -->
            <div class="nav-left">
                <div class="nav-logo">
                    <img src="~/images/vclass.png" alt="Logo" />
                </div>
                <h4 class="page-title">
                    <span>Faculty Panel</span> – @(ViewData["Title"] ?? "Dashboard")
                </h4>
            </div>

            <!-- RIGHT -->
            <div class="nav-right">
                @await Html.PartialAsync("_ProfileDropdown")
            </div>

        </div>

        <!-- CONTENT -->
        <div class="content">
            @RenderBody()
        </div>

    </div>

    <!-- SWEET ALERT -->
    @if (TempData["success"] != null)
    {
        <script>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: '@TempData["success"]',
                timer: 3000,
                showConfirmButton: false
            });
        </script>
    }

    @if (TempData["success2"] != null)
    {
        <script>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'info',
                title: '@TempData["success2"]',
                timer: 3000,
                showConfirmButton: false
            });
        </script>
    }

    @if (TempData["error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@TempData["error"]'
            });
        </script>
    }

    <!-- DROPDOWN JS -->
  

    <script>
        function pd_toggleDropdown() {
            document.getElementById("pdDropdown").classList.toggle("show");
        }

        window.addEventListener("click", function (e) {
            if (!e.target.closest('.pd-avatar')) {
                let dd = document.getElementById("pdDropdown");
                if (dd && dd.classList.contains("show")) {
                    dd.classList.remove("show");
                }
            }
        });

        function pd_confirmLogout() {
            Swal.fire({
                title: 'Are you sure?',
                text: "You will be logged out!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2563eb',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, Logout'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Account/Logout';
                }
            });
        }
    </script>
    <!-- ✅ ADD THESE SCRIPTS HERE -->

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

    @RenderSection("Scripts", required: false)
  

</body>
</html>