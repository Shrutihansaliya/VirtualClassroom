@model List<VirtualClassroom.Core.TblClassroom>

@{
    Layout = "~/Views/Faculty/_FacultyLayout.cshtml";
    ViewData["Title"] = "Faculty Dashboard";
}

@if (TempData["Success"] != null)
{
    <div class="toast show align-items-center text-bg-success">
        <div class="d-flex">
            <div class="toast-body">
                @TempData["Success"]
            </div>
        </div>
    </div>
}

<h2>Classroom</h2>

<div class="class-grid">

    @if (Model != null && Model.Count > 0)
    {
        foreach (var item in Model)
        {
            <div class="class-card">

                <!-- HEADER -->
                <div class="card-header dark">
                    <h5>@item.ClassName</h5>
                    <p>@item.Description</p>
                </div>

                <!-- BODY (optional image) -->
                @* 
                <div class="card-body">
                    <img src="~/images/class.png" class="class-img" />
                </div>
                *@

                <!-- FOOTER -->
                <div class="card-footer">

                    <i class="bi bi-folder"></i>

                    @* <table> *@
                    @*     <tr> *@
                    @*         <td> *@
                                <a href="/Classroom/InviteMembers?classroomId=@item.ClassroomId">
                                    <i class="bi bi-person-plus"></i> Add Members
                                </a>
                        @*     </td> *@
                        @* </tr> *@

                        @* <tr> *@
                        @*     <td> *@
                                <a href="/Classroom/Members?classroomId=@item.ClassroomId">
                                    <i class="bi bi-people"></i> View Members
                                </a>
                    @*         </td> *@
                    @*     </tr> *@
                    @* </table> *@

                    <i class="bi bi-three-dots-vertical"></i>

                </div>

            </div>
        }
    }
    else
    {
        <p>No classrooms available</p>
    }

</div>