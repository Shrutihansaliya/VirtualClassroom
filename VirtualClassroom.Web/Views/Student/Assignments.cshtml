@model List<VirtualClassroom.Core.TblAssignments>

@{
    Layout = "~/Views/Student/_StudentLayout.cshtml";
    var userId = Context.Session.GetInt32("UserId");
}

<style>
    /* ===== PAGE TITLE ===== */
    h3 {
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    /* ===== CARD ===== */
    .assignment-card {
        border: none;
        border-radius: 16px;
        background: #fff;
        transition: all 0.2s ease-in-out;
        overflow: hidden;
    }

        .assignment-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 14px 35px rgba(0,0,0,0.10);
        }

    /* ===== HEADER ===== */
    .card-header-custom {
        padding: 12px 14px;
        font-weight: 600;
        font-size: 14px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* ===== BODY ===== */
    .card-body {
        padding: 14px 16px;
    }

    .assignment-title {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .meta-text {
        font-size: 12.5px;
        color: #6c757d;
        margin-bottom: 5px;
    }

    /* ===== FILE CHIP ===== */
    .file-chip {
        display: inline-block;
        padding: 5px 9px;
        border-radius: 8px;
        background: #eef3ff;
        font-size: 12px;
        margin-top: 6px;
        text-decoration: none;
        color: #2f5cff;
    }

        .file-chip:hover {
            background: #e0e9ff;
        }

    /* ===== FOOTER ===== */
    .card-footer-custom {
        padding: 12px 14px;
        background: #fafafa;
        border-top: 1px solid #eee;
    }

    /* ===== BUTTONS (SMALL PROFESSIONAL) ===== */
    .btn {
        border-radius: 7px;
        font-size: 12px;
        padding: 4px 10px;
    }

    .form-control-sm {
        height: 30px;
        font-size: 12px;
    }

    /* spacing fix */
    .action-row {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        align-items: center;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<h3 class="mb-3">📚 My Assignments</h3>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No assignments found.
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            var submission = item.Submissions?
            .FirstOrDefault(s => s.StudentId == userId);

            <div class="col-md-4 mb-4">
                <div class="assignment-card shadow-sm h-100">

                    <!-- HEADER -->
                    <div class="card-header-custom bg-dark text-white">
                        <span>@item.Title</span>

                        @if (DateTime.Now <= item.DueDate)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Closed</span>
                        }
                    </div>

                    <!-- BODY -->
                    <div class="card-body">

                        <div class="assignment-title">
                            @item.Title
                        </div>

                        <div class="meta-text">
                            @item.Description
                        </div>

                        <div class="meta-text">
                            <b>Class:</b> @item.Classroom.ClassName
                        </div>

                        <div class="meta-text">
                            <b>Due:</b> @item.DueDate.ToString("dd MMM yyyy")
                        </div>

                        @if (!string.IsNullOrEmpty(item.FilePath))
                        {
                            <a href="@item.FilePath" target="_blank" class="file-chip">
                                📎 View Assignment File
                            </a>
                        }
                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer-custom">

                        @if (DateTime.Now <= item.DueDate)
                        {
                            <div class="action-row">

                                @if (submission != null)
                                {
                                    <form asp-controller="Submission"
                                          asp-action="EditSubmission"
                                          method="post"
                                          enctype="multipart/form-data"
                                          class="d-flex gap-2 align-items-center">

                                        <input type="hidden" name="submissionId" value="@submission.SubmissionId" />

                                        <input type="file"
                                               name="file"
                                               class="form-control form-control-sm"
                                               style="width:140px;" />

                                        <button class="btn btn-warning">
                                            ✏ Update
                                        </button>
                                    </form>

                                    @if (!string.IsNullOrEmpty(submission.FilePath))
                                    {
                                        <a asp-controller="Submission"
                                           asp-action="ViewSubmissionFile"
                                           asp-route-submissionId="@submission.SubmissionId"
                                           class="btn btn-info">
                                            👁 View
                                        </a>
                                    }

                                    <a asp-controller="Submission"
                                       asp-action="DeleteSubmission"
                                       asp-route-submissionId="@submission.SubmissionId"
                                       class="btn btn-outline-danger">
                                        🗑
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Submission"
                                       asp-action="Submit"
                                       asp-route-assignmentId="@item.AssignmentId"
                                       class="btn btn-success">
                                        📤 Submit
                                    </a>
                                }

                            </div>
                        }
                        else
                        {
                            <span class="text-danger fw-semibold small d-block mb-2">
                                ⛔ Deadline Passed
                            </span>

                            @if (submission != null && !string.IsNullOrEmpty(submission.FilePath))
                            {
                                <a asp-controller="Submission"
                                   asp-action="ViewSubmissionFile"
                                   asp-route-submissionId="@submission.SubmissionId"
                                   class="btn btn-info">
                                    👁 View
                                </a>
                            }
                        }

                    </div>
                </div>
            </div>
        }
    </div>
}