@model List<VirtualClassroom.Core.TblAssignments>

@{
    Layout = "~/Views/Student/_StudentLayout.cshtml"; // your layout file
}

<h3>My Assignments</h3>

@if (!Model.Any())
{
    <p>No assignments found.</p>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card p-3 shadow-sm">
                    <h5>@item.Title</h5>
                    <p>@item.Description</p>

                    <small><b>Class:</b> @item.Classroom.ClassName</small><br />
                    <small><b>Due:</b> @item.DueDate.ToShortDateString()</small>

                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        <br />
                        <a href="@item.FilePath" target="_blank" class="btn btn-sm btn-primary mt-2">
                            View File
                        </a>
                    }
                </div>
            </div>
        }
    </div>

