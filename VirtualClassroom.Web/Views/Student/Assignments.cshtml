@model List<VirtualClassroom.Core.TblAssignments>

@{
    Layout = "~/Views/Student/_StudentLayout.cshtml"; // your layout file
    var userId = Context.Session.GetInt32("UserId");
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<h3>My Assignments</h3>

@if (!Model.Any())
{
    <p>No assignments found.</p>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            var submission = item.Submissions?
            .FirstOrDefault(s => s.StudentId == userId);
            <div class="col-md-4 mb-3">
                <div class="card p-3 shadow-sm">
                    <h5>@item.Title</h5>
                    <p>@item.Description</p>

                    <small><b>Class:</b> @item.Classroom.ClassName</small><br />
                    <small><b>Due:</b> @item.DueDate.ToShortDateString()</small>

                    @if (!string.IsNullOrEmpty(item.FilePath))
                    {
                        <br />
                        <a href="@item.FilePath" target="_blank" class="btn btn-sm btn-primary mt-2">
                            View File
                        </a>
                    }

                    @* <a asp-controller="Submission" *@
                    @*    asp-action="Submit" *@
                    @*    asp-route-assignmentId="@item.AssignmentId" *@
                    @*    class="btn btn-success btn-sm mt-2"> *@
                    @*     📤 Submit *@
                    @* </a> *@

                    @if (DateTime.Now <= item.DueDate)
                    {
                        if (submission != null)
                        {
                            <form asp-controller="Submission" asp-action="EditSubmission" method="post" enctype="multipart/form-data" class="mt-2">
                                <input type="hidden" name="submissionId" value="@submission.SubmissionId" />
                                <input type="file" name="file" class="form-control form-control-sm" required />
                                <button type="submit" class="btn btn-warning btn-sm mt-1">✏ Update</button>
                            </form>

                            <a asp-controller="Submission"
                               asp-action="DeleteSubmission"
                               asp-route-submissionId="@submission.SubmissionId"
                               class="btn btn-danger btn-sm mt-1">
                                🗑 Delete
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Submission"
                               asp-action="Submit"
                               asp-route-assignmentId="@item.AssignmentId"
                               class="btn btn-success btn-sm mt-2">
                                📤 Submit
                            </a>
                        }
                    }
                    else
                    {
                        <span class="text-danger fw-bold">⛔ Deadline Passed</span>
                    }

                </div>
            </div>
        }
    </div>

    @* <h3>All Assignments</h3> *@

    @* @foreach (var group in Model.GroupBy(a => a.Classroom.ClassName)) *@
    @* { *@
    @*     <h4 class="mt-4">@group.Key</h4> *@

    @*     <div class="row"> *@
    @*         @foreach (var item in group) *@
    @*         { *@
    @*             <div class="col-md-4"> *@
    @*                 <div class="card p-3 mb-3"> *@
    @*                     <h5>@item.Title</h5> *@
    @*                     <p>@item.Description</p> *@
    @*                     <small>Due: @item.DueDate</small> *@
    @*                 </div> *@
    @*             </div> *@
    @*         } *@
    @*     </div> *@
    @* } *@
}