    @*         { *@
    @*             <div class="col-md-4"> *@
    @*                 <div class="card p-3 mb-3"> *@
    @*                     <h5>@item.Title</h5> *@
    @*                     <p>@item.Description</p> *@
    @*                     <small>Due: @item.DueDate</small> *@
    @*                 </div> *@
    @*             </div> *@
    @*         } *@
    @*     </div> *@
    @* } *@
}