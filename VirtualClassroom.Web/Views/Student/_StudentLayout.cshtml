<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/student.css" rel="stylesheet" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <!-- ✅ ADD THIS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>

    <!-- SIDEBAR -->
    @* <div class="std-sidebar"> *@
    @*     <ul> *@
    @*         <li><a asp-controller="Student" asp-action="Dashboard"><i class="bi bi-house"></i><span>Dashboard</span></a></li> *@
    @*         <li><i class="bi bi-journal"></i><span>My Classes</span></li> *@
    @*         <li><i class="bi bi-file-text"></i><span>Assignments</span></li> *@
    @*         <li><i class="bi bi-upload"></i><span>Submissions</span></li> *@
    @*         <li><i class="bi bi-camera-video"></i><span>Live Sessions</span></li> *@
    @*     </ul> *@
    @* </div> *@


    <div class="std-sidebar">
        <ul>

            <li>
                <a asp-controller="Student" asp-action="Dashboard">
                    <i class="bi bi-house"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="MyClassrooms">
                    <i class="bi bi-journal"></i>
                    <span>My Classes</span>
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="PendingInvites">
                    <i class="bi bi-envelope"></i>
                    <span>Pending Invites</span>
                </a>
            </li>

            <li>
                <a asp-controller="Assignment" asp-action="Index">
                    <i class="bi bi-file-text"></i><span>Assignments</span>
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="Submissions">
                    <i class="bi bi-upload"></i>
                    <span>Submissions</span>
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="LiveSessions">
                    <i class="bi bi-camera-video"></i>
                    <span>Live Sessions</span>
                </a>
            </li>

        </ul>
    </div>

    <div class="std-main">

        <!-- MAIN -->
        <!-- NAVBAR -->
        <div class="student-navbar">
            <h4>Student Classroom</h4>

            <div class="right">
                <i class="bi bi-plus-lg"></i>
                <i class="bi bi-grid-3x3-gap"></i>

                <!-- PROFILE DROPDOWN -->
                <div class="dropdown">
                    <div class="profile-circle" onclick="toggleDropdown()">
                        @Context.Session.GetString("UserName")?.Substring(0, 1)
                    </div>

                    <div id="profileMenu" class="dropdown-menu">
                        <p>@Context.Session.GetString("UserName")</p>
                        <p>@Context.Session.GetString("UserEmail")</p>

                        <a href="/Account/Profile">My Profile</a>
                        <a href="/Account/Logout">Logout</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- CONTENT -->
        <div class="student-content">
            @RenderBody()
        </div>

    </div>

</body>

</html>
<script>
    function toggleDropdown() {
        var menu = document.getElementById("profileMenu");
        menu.style.display = menu.style.display === "block" ? "none" : "block";
    }

    // Close when clicking outside
    window.onclick = function (e) {
        if (!e.target.matches('.profile-circle')) {
            var dropdown = document.getElementById("profileMenu");
            if (dropdown) dropdown.style.display = "none";
        }
    }
</script>