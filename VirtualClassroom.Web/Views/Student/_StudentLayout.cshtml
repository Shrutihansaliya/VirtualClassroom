<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/student.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/profile-dropdown.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <!-- ✅ ADD THIS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="std-sidebar">
        <ul>
            <li><a asp-controller="Student" asp-action="Dashboard"><i class="bi bi-house"></i><span>Dashboard</span></a></li>
            <li><i class="bi bi-journal"></i><span>My Classes</span></li>
            <li><i class="bi bi-file-text"></i><span>Assignments</span></li>
            <li><i class="bi bi-upload"></i><span>Submissions</span></li>
            <li><i class="bi bi-camera-video"></i><span>Live Sessions</span></li>
        </ul>
    </div>

    <div class="std-main">

    <!-- MAIN -->
   

        <!-- NAVBAR -->
        <div class="student-navbar">

            <!-- LEFT -->
            <div class="nav-left">
                <h4>Student Classroom</h4>
            </div>

            <!-- RIGHT -->
            <div class="nav-right">

                <!-- ICONS -->
                <div class="nav-icons">
                    <i class="bi bi-plus-lg"></i>
                    <i class="bi bi-grid-3x3-gap"></i>
                </div>

                <!-- PROFILE -->
                <div class="nav-profile">
                    @await Html.PartialAsync("_ProfileDropdown")
                </div>

            </div>

        </div>

        <!-- CONTENT -->
        <div class="student-content">
            @RenderBody()
        </div>

    </div>

</body>

</html>
<script>
    function pd_toggleDropdown() {
        document.getElementById("pdDropdown").classList.toggle("show");
    }

    window.addEventListener("click", function (e) {
        if (!e.target.closest('.pd-avatar')) {
            let dd = document.getElementById("pdDropdown");
            if (dd && dd.classList.contains("show")) {
                dd.classList.remove("show");
            }
        }
    });

    function pd_confirmLogout() {
        Swal.fire({
            title: 'Are you sure?',
            text: "You will be logged out!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#2563eb',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, Logout'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Account/Logout';
            }
        });
    }
</script>
