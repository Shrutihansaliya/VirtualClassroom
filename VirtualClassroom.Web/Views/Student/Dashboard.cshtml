   @*      } *@

    @foreach (var item in Model)
    {
        <a asp-controller="Assignment"
           asp-action="ByClass"
           asp-route-classId="@item.ClassroomId"
           style="text-decoration:none; color:inherit; display:block;">

            <div style="width:250px; border-radius:10px; padding:15px;
                    background:#f5f5f5; box-shadow:0 2px 5px rgba(0,0,0,0.2);
                    cursor:pointer; transition:0.2s;">

                <h3>@item.ClassName</h3>
                <p>@item.Description</p>

                <small style="color:gray;">Click to view assignments →</small>

            </div>
        </a>
    }
    @* </div> *@
}
