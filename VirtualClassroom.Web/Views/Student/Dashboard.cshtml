@{
    Layout = "~/Views/Student/_StudentLayout.cshtml";
}
@model List<VirtualClassroom.Core.TblClassroom>

<h2 class="page-title">My Classes</h2>

@if (Model == null || !Model.Any())
{
    <p>No classes joined yet</p>
}
else
{
    <div class="class-grid">

        @foreach (var item in Model)
        {
            <a asp-controller="Assignment"
               asp-action="ByClass"
               asp-route-classId="@item.ClassroomId"
               style="text-decoration:none; color:inherit;">

                <div class="class-card">

                    <div class="class-card-header">
                        @item.ClassName
                    </div>

                    <div class="class-card-body">
                        <p>@item.Description</p>
                    </div>

                    <div class="class-card-footer">
                        View Assignments
                    </div>

                </div>

            </a>
        }

    </div>
}