@model List<VirtualClassroom.Core.TblClassroom>

<h2>My Classes</h2>

@if (Model == null || !Model.Any())
{
    <p>No classes joined yet</p>
}
else
{
    
   @*  <div style="display:flex; gap:20px; flex-wrap:wrap;"> *@
