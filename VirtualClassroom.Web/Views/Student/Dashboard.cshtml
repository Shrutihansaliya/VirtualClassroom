@{
    Layout = "~/Views/Student/_StudentLayout.cshtml";
}
@model List<VirtualClassroom.Core.TblClassroom>

<h2 class="page-title">My Classes</h2>

@if (Model == null || !Model.Any())
{
    <p>No classes joined yet</p>
}
else
{
    <div class="class-grid">

        @foreach (var item in Model)
        {
            <div class="class-card">

                <div class="class-card-header">
                    @item.ClassName
                </div>

                <div class="class-card-body">
                    <p>@item.Description</p>
                </div>

                <div class="class-card-footer"
                     style="display:flex; justify-content:space-between; align-items:center; gap:10px;">

                    <!-- Assignments Button -->
                    <a asp-controller="Assignment"
                       asp-action="ByClass"
                       asp-route-classId="@item.ClassroomId"
                       class="btn btn-sm btn-primary">
                        Assignments
                    </a>

                    <!-- Materials Button -->
                    <a asp-controller="Material"
                       asp-action="ByClass"
                       asp-route-classId="@item.ClassroomId"
                       class="btn btn-sm btn-outline-primary">
                        Materials
                    </a>

                </div>

            </div>
        }

    </div>
}