
@model List<VirtualClassroom.Core.TblSubmissions>

@{
    ViewData["Title"] = "Submissions";
    Layout = "~/Views/Faculty/_FacultyLayout.cshtml";
}

<link rel="stylesheet" href="~/css/assignment/submissions.css" asp-append-version="true" />

<div class="submission-page">
    <div class="top-bar">
        <a asp-controller="AssignmentFaculty" asp-action="Classrooms" class="back-btn">

            ← Back to Classrooms
        </a>
    </div>
    <div class="submission-header">
        <h2>📄 Student Submissions</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            No submissions available yet.
        </div>
    }
    else
    {
        <div class="submission-card">

            <table class="submission-table">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Status</th>
                        <th>File</th>
                        <th>Submitted On</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(item.Student?.FullName ?? "N/A")</td>

                            <td>
                                @if (item.Status == "Submitted")
                                {
                                    <span class="status submitted">Submitted</span>
                                }
                                else
                                {
                                    <span class="status pending">Pending</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(item.FilePath))
                                {
                                    <a href="@item.FilePath" target="_blank" class="view-btn">View</a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>

                            <td>
                                @(item.SubmittedAt.HasValue
                                    ? item.SubmittedAt.Value.ToString("dd MMM yyyy, hh:mm tt")
                                    : "-")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    }

</div>