@{
    var role = Context.Session.GetString("UserRole");

    if (role == "Faculty")
    {
        Layout = "~/Views/Faculty/_FacultyLayout.cshtml";
    }
    else
    {
        Layout = "~/Views/Student/_StudentLayout.cshtml";
    }

    ViewData["Title"] = "Change Password";
}

<link href="~/css/change-password.css" rel="stylesheet" />

<div class="cp-container">
    <div class="cp-card">
        <h2>🔐 Change Password</h2>

        <form method="post" id="passwordForm">

            <!-- CURRENT -->
            <div class="form-group">
                <label>Current Password</label>
                <div class="input-box">
                    <input type="password" name="currentPassword" id="currentPassword" required />
                    <span onclick="togglePassword('currentPassword', this)">👁</span>
                </div>
            </div>

            <!-- NEW -->
            <div class="form-group">
                <label>New Password</label>
                <div class="input-box">
                    <input type="password" name="newPassword" id="newPassword" required />
                    <span onclick="togglePassword('newPassword', this)">👁</span>
                </div>
                <small id="strengthText"></small>
            </div>

            <!-- CONFIRM -->
            <div class="form-group">
                <label>Confirm Password</label>
                <div class="input-box">
                    <input type="password" name="confirmPassword" id="confirmPassword" required />
                    <span onclick="togglePassword('confirmPassword', this)">👁</span>
                </div>
                <small id="matchText"></small>
            </div>

            <button type="submit">Update Password</button>
        </form>
    </div>
</div>

<!-- TOAST -->
@if (TempData["Success"] != null)
{
    <div class="toast success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="toast error">@TempData["Error"]</div>
}

<script>
    // 👁 TOGGLE PASSWORD
    function togglePassword(id, el) {
        let input = document.getElementById(id);
        if (input.type === "password") {
            input.type = "text";
            el.innerText = "🙈";
        } else {
            input.type = "password";
            el.innerText = "👁";
        }
    }

    // 🔥 PASSWORD STRENGTH
    document.getElementById("newPassword").addEventListener("keyup", function () {
        let val = this.value;
        let strength = document.getElementById("strengthText");

        let regex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{6,}$/;

        if (regex.test(val)) {
            strength.innerHTML = "Strong Password ✅";
            strength.style.color = "lime";
        } else {
            strength.innerHTML = "Weak Password ❌";
            strength.style.color = "red";
        }
    });

    // 🔥 MATCH CHECK
    document.getElementById("confirmPassword").addEventListener("keyup", function () {
        let newPass = document.getElementById("newPassword").value;
        let confirm = this.value;
        let text = document.getElementById("matchText");

        if (newPass === confirm) {
            text.innerHTML = "Passwords match ✅";
            text.style.color = "lime";
        } else {
            text.innerHTML = "Passwords do not match ❌";
            text.style.color = "red";
        }
    });

    // 🔥 TOAST AUTO HIDE
    setTimeout(() => {
        document.querySelectorAll(".toast").forEach(t => t.style.display = "none");
    }, 3000);
</script>