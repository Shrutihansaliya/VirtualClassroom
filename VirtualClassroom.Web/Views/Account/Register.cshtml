

@* new one *@

@model VirtualClassroom.Core.TblUsers

@{
    Layout = null;
}

<link rel="stylesheet" href="~/css/register.css" />

<div class="main-container">

    <!-- LEFT PANEL -->
    <div class="left-panel">
        <div class="brand">
            <h1>Virtual Classroom</h1>
            <p>Learn • Teach • Collaborate</p>
        </div>

        <div class="features">
            @* <h3>Why Join?</h3> *@
            <ul>
                <li>📚 Create & Join Classrooms</li>
                <li>📝 Submit & Manage Assignments</li>
                <li>🎥 Attend Live Sessions</li>
                <li>👨‍🏫 Faculty & Student Roles</li>
                <li>🔐 Secure Google Login</li>
            </ul>
        </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right-panel">
        <div class="login-container">
            <h2>Create Account 🚀</h2>
            <p class="subtitle">Register to get started</p>

            <form asp-action="Register" method="post">

                <!-- Validation -->
                <div asp-validation-summary="All" class="text-danger"></div>

                <!-- Full Name -->
                <input asp-for="FullName" placeholder="Username" required />
                <span asp-validation-for="FullName" class="text-danger"></span>

                <!-- Email -->
                <input asp-for="Email" type="email" placeholder="Email Address" required />
                <span asp-validation-for="Email" class="text-danger"></span>

                <!-- Password -->
                <input asp-for="PasswordHash" type="password" placeholder="Password" required />
                <span asp-validation-for="PasswordHash" class="text-danger"></span>

                <!-- Role -->
                <select asp-for="Role" required>
                    <option value="">Select Role</option>
                    <option value="1">Faculty</option>
                    <option value="2">Student</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>

                <!-- Error -->
                @if (ViewBag.Error != null)
                {
                    <p class="error">@ViewBag.Error</p>
                }

                <button type="submit" class="login-btn">Register</button>

                <p class="or">or</p>

                <!-- Google Login -->
                <button type="button" class="google-btn"
                        onclick="location.href='@Url.Action("GoogleLogin","Account")'">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                         class="google-icon" />
                    Continue with Google
                </button>

                <p class="register-link">
                    Already have an account?
                    <a href="/Account/Login">Login</a>
                </p>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}