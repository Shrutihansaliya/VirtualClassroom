




 @* new css *@

@{
    Layout = null;
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="main-container">

    <!-- LEFT SIDE (Branding + Info) -->
    <div class="left-panel">
        
    </div>

    <!-- RIGHT SIDE (LOGIN FORM) -->
    <div class="right-panel">
        <div class="login-container">
            <div class="logo">
                <img src="~/images/vclass.png" alt="vClass Logo" />
                <p class="logo-text">Smart learning platform for students & faculty</p>
            </div>
            <h2>Welcome Back 👋</h2>
            <p class="subtitle">Login to continue</p>

            <form method="post">
                <input type="email" name="email" placeholder="Email Address" required />
               
                <!-- 🔥 PASSWORD WITH TOGGLE -->
                <div class="password-wrapper">
                    <input type="password" id="password" name="password" placeholder="Password" required />
                    <span class="toggle-password" onclick="togglePassword()">👁</span>
                </div>


                <div class="forgot-container">
                    <a href="@Url.Action("ForgotPassword","Account")" class="forgot-link">
                        Forgot password?
                    </a>
                </div>

                <button type="submit" class="login-btn">Log In</button>

                <p class="or">or</p>

                <button type="button" class="google-btn"
                        onclick="location.href='@Url.Action("GoogleLogin","Account")'">
                    <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg"
                         class="google-icon" />
                    Continue with Google
                </button>

                <p class="register-link">
                    Don't have an account?
                    <a href="/Account/Register">Create Account</a>
                </p>



            </form>

            @if (ViewBag.Error != null)
            {
                <p class="error">@ViewBag.Error</p>
            }
        </div>
    </div>

</div>
<!-- 🔥 PASSWORD SCRIPT -->
<script>
    function togglePassword() {
        const pass = document.getElementById("password");
        pass.type = pass.type === "password" ? "text" : "password";
    }
</script>